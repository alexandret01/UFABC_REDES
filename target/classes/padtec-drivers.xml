<drivers>
    <driver name="padtec" manufacturer="Padtec" hwVersion="SPVL4" swVersion="1.0">
        <behaviour api="org.onosproject.net.optical.OpticalDevice"
                   impl="org.onosproject.net.optical.DefaultOpticalDevice"/>

        <!-- Conectividade gRPC/gNMI -->
        <behaviour api="org.onosproject.net.device.DeviceHandshaker"
                   impl="org.onosproject.drivers.padtec.GnmiHandshaker"/>

        <!-- Descoberta de Dispositivo e Portas -->
        <behaviour api="org.onosproject.net.device.DeviceDescriptionDiscovery"
                   impl="org.onosproject.drivers.padtec.PadtecDeviceDescription"/>

        <!-- Estatísticas de Porta -->
        <behaviour api="org.onosproject.net.device.PortStatisticsDiscovery"
                   impl="org.onosproject.drivers.padtec.PadtecDeviceDescription"/>

        <!-- Behaviours não implementados (Stubs) - Descomente se precisar carregar as classes vazias -->
