<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE web-app PUBLIC "-//Sun Microsystems, Inc.//DTD Web Application 2.3//EN"
        "http://java.sun.com/dtd/web-app_2_3.dtd">
<web-app>
    <display-name>UFABC Optical Lab Monitor API</display-name>

    <servlet>
        <servlet-name>JAX-RS Service</servlet-name>
        <servlet-class>com.sun.jersey.spi.container.servlet.ServletContainer</servlet-class>
        <!--
          AbstractWebApplication registra os recursos JAX-RS diretamente (sem OSGi lookup).
          Este é o padrão usado por todos os apps ONOS com REST API (ex: faultmanagement, cpman).
        -->
        <init-param>
            <param-name>javax.ws.rs.Application</param-name>
            <param-value>org.onosproject.opticallab.OpticalLabWebApplication</param-value>
        </init-param>
        <load-on-startup>1</load-on-startup>
    </servlet>

    <servlet-mapping>
        <servlet-name>JAX-RS Service</servlet-name>
        <url-pattern>/*</url-pattern>
    </servlet-mapping>
</web-app>
